# Base URL for REST/GraphQL via API gateway. Empty = relative paths (nginx proxy in Docker).
VITE_API_BASE_URL=http://localhost:8000

# Keycloak URL as reachable from the BROWSER.
VITE_KEYCLOAK_URL=http://localhost:8080

# Notification-service WebSocket URL. Empty = relative via window.location
# (Vite proxy in dev, nginx proxy in Docker). Set only to bypass the proxies.
VITE_NOTIFICATION_WS_URL=
